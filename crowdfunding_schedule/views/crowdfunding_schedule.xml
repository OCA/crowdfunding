<odoo>
    <record
        id="crowdfunding_challenge_form_datetime_schedule_inherit"
        model="ir.ui.view"
    >
        <field name="name">crowdfunding.challenge.form.datetime.schedule</field>
        <field name="model">crowdfunding.challenge</field>
        <field name="inherit_id" ref="crowdfunding.view_crowdfunding_challenge_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pledged_amount']" position="after">
                <field name="start_datetime" />
                <field name="end_datetime" />
            </xpath>
        </field>
    </record>
</odoo>
