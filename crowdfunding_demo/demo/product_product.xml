<odoo noupdate="1">
    <record
        id="crowdfunding.product_crowdfunding"
        model="product.product"
        forcecreate="False"
    >
        <!-- set 0% tax on crowdfunding product -->
        <field
            name="taxes_id"
            eval="[(6, 0, [ref('l10n_ch.1_vat_other_movements_910')])]"
        />
        <field
            name="supplier_taxes_id"
            eval="[(6, 0, [ref('l10n_ch.1_vat_77_purchase_reverse')])]"
        />
    </record>
</odoo>
